<monsters xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../schema/monster.xsd">
  <monster>
    <name>POUPÉE DES ÂMES</name>
    <type>CRÉATURE</type>
    <level>2</level>
    <creatureTraits>
      <trait type="size" ref="trait-tres-petite">TRÈS PETITE</trait>
      <trait>ÂME</trait>
      <trait>CRÉATURE</trait>
      <trait>ARTIFICIELLE</trait>
    </creatureTraits>
    <perception>
      <bonus/>
    </perception>
    <attributes STR="+0" DEX="+0" CON="+0" INT="+0" WIS="+0" CHA="+0"/>
    <interactionAbilities>
      <special>
        <name>Langue</name>
        <description>une langue parlée par son créateur (généralement le commun)</description>
      </special>
      <special>
        <name>Compétence</name>
        <description>Acrobaties +8, Discrétion +8, Occultisme +4</description>
      </special>
      <special>
        <name>For</name>
        <description>–2, **Dex **+4, **Con **+3, **Int **+0, **Sag **+2, **Cha **+0</description>
      </special>
      <special>
        <name>Fragments de personnalité</name>
        <description>Une poupée des âmes partage des fragments de personnalité de la personne à qui appartenait l’âme, mais aucun de ses souvenirs� Cela implique que la poupée des âmes sera proche d’un fort trait de personnalité de l’âme du donneur (voir encadré)� En raison de ce fragment d’âme, une poupée des âmes n’est pas immunisée contre le trait esprit comme la plupart des créatures artificielles�</description>
      </special>
    </interactionAbilities>
    <armorClass>17</armorClass>
    <saves REF="+10" FOR="+7" WIL="+6"/>
    <health>23</health>
    <immunities>
      <immunity>attaques non létales</immunity>
      <immunity>condamné</immunity>
