      <immunity>sommeil</immunity>
    </immunities>
    <speeds>
      <speed>0 m</speed>
    </speeds>
    <strikes>
      <strike type="melee">
        <name>crocs +19, **Dégâts **2d12+10 perforants **Corps à corps** 1 queue,</name>
        <bonus>+19</bonus>
        <traits>
          <trait>allonge 3 m</trait>
        </traits>
        <damages>
          <damage>
            <amount>2d8+10</amount>
            <damageType>contondants</damageType>
          </damage>
        </damages>
      </strike>
    </strikes>
    <offensiveAbilities>
      <special>
        <name>Agresseur surprise</name>
        <description>Au premier round de combat, les créatures qui n’ont pas encore agi sont prises par surprise par le drake du désert�</description>
      </special>
      <special type="activity" actions="2">
        <name>Frénésie draconique</name>
        <description>Le drake du désert effectue deux Frappes de crocs et une Frappe de queue dans l’ordre qu’il veut�</description>
      </special>
      <special type="activity" actions="2">
        <name>Souffle des sables</name>
        <traits>
          <trait ref="trait-primordiale">primordiale</trait>
          <trait ref="trait-terre">terre</trait>
        </traits>
        <description>Le drake du désert projette une boule de sable abrasif qui traverse une distance de 18 m avant de former un nuage en une explosion de 4,5 m de rayon� Les créatures dans la zone d’effet subissent 9d6 dégâts tranchants (jet de Réflexes basique DD 27)� Le drake du désert ne peut plus utiliser Souffle des sables pendant 1d6 rounds� Durant ce laps de temps, la tempête de sable reste dans la zone� Ceci confère l’état masqué à tout ce qui se trouve à l’intérieur de la zone, mais ce qui se trouve à l’extérieur de la tempête bénéficie de l’état masqué pour les créatures situées à l’intérieur�</description>
      </special>
      <special type="activity" actions="1">
        <name>Vitesse augmentée</name>
        <traits>
          <trait ref="trait-deplacement">déplacement</trait>
        </traits>
        <description>**Fréquence** trois fois par jour�</description>
      </special>
    </offensiveAbilities>
