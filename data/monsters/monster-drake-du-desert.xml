<monsters xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../schema/monster.xsd">
  <monster>
    <name>DRAKE DU DÉSERT</name>
    <type>CRÉATURE</type>
    <level>8</level>
    <creatureTraits>
      <trait type="size" ref="trait-grande">GRANDE</trait>
      <trait ref="trait-dragon">DRAGON</trait>
      <trait ref="trait-terre">TERRE</trait>
    </creatureTraits>
    <perception>
      <bonus>+15</bonus>
      <senses>
        <sens>
          <name>odorat</name>
          <precision>imprécis</precision>
          <range>9 m</range>
        </sens>
        <sens>
          <name>vision dans le noir</name>
        </sens>
        <sens>
          <name>vision malgré les tempêtes de sable</name>
        </sens>
      </senses>
    </perception>
    <skills>
      <skill>
        <name>Acrobaties</name>
        <bonus>+17</bonus>
      </skill>
      <skill>
        <name>Athlétisme</name>
        <bonus>+18</bonus>
      </skill>
      <skill>
        <name>Discrétion</name>
        <bonus>+15</bonus>
      </skill>
      <skill>
        <name>Intimidation</name>
        <bonus>+13</bonus>
      </skill>
      <skill>
        <name>Survie</name>
        <bonus>+15</bonus>
      </skill>
    </skills>
    <attributes STR="+6" DEX="+3" CON="+5" INT="+0" WIS="+3" CHA="+1"/>
    <armorClass>27</armorClass>
    <saves REF="+15" FOR="+17" WIL="+13"/>
