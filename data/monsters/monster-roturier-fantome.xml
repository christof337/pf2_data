          <trait ref="trait-mental">mental</trait>
          <trait ref="trait-terreur">terreur</trait>
        </traits>
        <description>DD 21</description>
      </special>
      <special>
        <name>Mage fantôme</name>
        <description>Un magicien mort avant d’avoir achevé sa tâche peut revenir sous la forme d’un mage fantôme.</description>
