<?xml version='1.0' encoding='UTF-8'?>
<?xml-stylesheet href="../../xslt/decodeMonster.xsl" type="text/xsl"?>
<monsters xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../schema/monster.xsd">
  <monster>
    <name>ROTURIER FANTÔME</name>
    <type>CRÉATURE</type>
